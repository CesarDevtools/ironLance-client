{
	"headers": [
		{
			"source": "/sitemap.xml",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/xml; charset=utf-8"
				},
				{
					"key": "Cache-Control",
					"value": "public, max-age=0"
				}
			]
		},
		{
			"source": "/robots.txt",
			"headers": [
				{
					"key": "Content-Type",
					"value": "text/plain; charset=utf-8"
				},
				{
					"key": "Cache-Control",
					"value": "public, max-age=3600"
				}
			]
		}
	],
	"rewrites": [
		{
			"source": "/sitemap.xml",
			"destination": "https://ironlance-server.vercel.app/sitemap.xml"
		},
		{
			"source": "/(.*)",
			"destination": "/index.html"
		}
	]
}